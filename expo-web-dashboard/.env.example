# ─────────────────────────────────────────────────────────────
# expo-web-dashboard (admin / investor dashboard + public visitor map)
# Copy this file to `.env.local` and fill in YOUR values.
# `.env.local` is git-ignored. Only VITE_-prefixed vars reach the browser,
# so NEVER put secrets (tokens, passwords, DB URIs) in a VITE_ variable.
# ─────────────────────────────────────────────────────────────

# Base URL of the NestJS backend API (trailing slash optional — normalized).
# Desktop dev can leave this unset (falls back to http://localhost:3000).
# For LAN / phone testing use your laptop IPv4 from `ipconfig` (NOT localhost —
# on a phone, localhost is the phone itself), e.g.:
# VITE_API_URL=http://192.168.1.5:3000
VITE_API_URL=

# URL of the PUBLIC visitor map (the separate expo-mobile-app, which runs on
# port 5173 and serves the map at its root path). Used to build the Visitor QR.
# Leave UNSET to derive it from the browser: the SAME hostname the dashboard was
# opened from, on the visitor app's port — so opening the dashboard via the LAN
# IP (http://<LAPTOP_IPV4>:5180) yields a phone-scannable http://<LAPTOP_IPV4>:5173/
# with zero config. Set it explicitly only for a custom host or production, e.g.:
# VITE_VISITOR_MAP_URL=http://192.168.1.5:5173/
# VITE_VISITOR_MAP_URL=https://map.your-hopex-domain.com
VITE_VISITOR_MAP_URL=

# Override the visitor app's port if you changed it from the default 5173.
# VITE_VISITOR_MAP_PORT=5173

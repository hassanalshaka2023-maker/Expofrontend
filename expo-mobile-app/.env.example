# ─────────────────────────────────────────────────────────────
# expo-mobile-app (public visitor 3D map) — environment example
# Copy this file to `.env.local` and fill in YOUR values.
# `.env.local` is git-ignored, so your laptop IP is never committed.
# Only variables prefixed with VITE_ are exposed to the browser.
# ─────────────────────────────────────────────────────────────

# Base URL of the NestJS backend API (no trailing slash needed — it is
# normalized automatically). Pick ONE per situation:

# 1) Desktop-only dev (laptop browser). You can also just leave it unset;
#    the app falls back to http://localhost:3000.
# VITE_API_URL=http://localhost:3000

# 2) Phone / LAN testing — REQUIRED so the phone can reach the laptop.
#    Replace with your laptop's IPv4 (run `ipconfig` → "IPv4 Address").
#    Do NOT use localhost here: on the phone, localhost is the phone itself.
# VITE_API_URL=http://192.168.1.5:3000

# 3) Production — the publicly deployed API origin.
# VITE_API_URL=https://api.your-domain.com
